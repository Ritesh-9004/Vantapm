# ── Packman Crawler — Environment Variables ──────────────
# Copy this file to .env and fill in YOUR values.

# GitHub Personal Access Token (Classic)
# Create at: https://github.com/settings/tokens
# Required scopes: public_repo, read:org, read:user
GITHUB_TOKEN=ghp_your_token_here

# PostgreSQL connection
DATABASE_URL=postgresql://postgres:dev@localhost:5432/packman

# Crawler settings (optional — defaults shown)
CRAWL_INTERVAL_HOURS=6
MAX_REPOS_PER_RUN=50
MIN_STARS=5
RETRY_FAILED_FIRST=true
RESCAN_SUCCESS_AFTER_HOURS=24
