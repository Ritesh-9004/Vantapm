{
  "name": "@vanta/cli",
  "version": "0.2.0",
  "description": "Universal MCU package manager CLI",
  "type": "module",
  "bin": {
    "vanta": "./src/index.ts"
  },
  "scripts": {
    "dev": "echo \"@vanta/cli ready — run: bun src/index.ts <command>\"",
    "build": "bun build src/index.ts --compile --outfile vanta",
    "build:win": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile vanta.exe"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "@inquirer/prompts": "^7.0.0",
    "semver": "^7.6.0",
    "tar": "^7.4.0",
    "@iarna/toml": "^2.2.5",
    "@vanta/types": "workspace:*"
  },
  "devDependencies": {
    "@types/semver": "^7.5.0",
    "@types/tar": "^6.1.0",
    "bun-types": "^1.1.0",
    "typescript": "^5.7.0"
  }
}
